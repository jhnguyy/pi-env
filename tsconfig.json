{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    ".pi/extensions/**/*.ts",
    ".agents/**/*.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    ".pi/extensions/*/dist"
  ]
}
