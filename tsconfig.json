{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types"]
  },
  "include": [
    ".pi/extensions/**/*.ts",
    ".agents/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".pi/extensions/*/dist"
  ]
}
