    "breadcrumb.foreground":         "#7c6f64",
    "breadcrumb.focusForeground":    "#ebdbb2",
    "breadcrumb.activeSelectionForeground": "#ebdbb2",
    "breadcrumbPicker.background":   "#3c3836",

    "symbolIcon.classForeground":    "#8ec07c",
    "symbolIcon.functionForeground": "#fabd2f",
    "symbolIcon.variableForeground": "#83a598",
    "symbolIcon.keywordForeground":  "#fb4934",
    "symbolIcon.stringForeground":   "#b8bb26",
    "symbolIcon.numberForeground":   "#d3869b"
  },

  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#928374", "fontStyle": "italic" }
    },
    {
      "name": "String",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#b8bb26" }
    },
    {
      "name": "String escape / interpolation punctuation",
      "scope": ["constant.character.escape", "punctuation.definition.template-expression"],
      "settings": { "foreground": "#8ec07c" }
    },
    {
      "name": "Number / Boolean / Null",
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#d3869b" }
    },
    {
      "name": "Keyword",
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.delete"],
      "settings": { "foreground": "#fb4934" }
    },
    {
      "name": "Storage type (let/const/var/function/class)",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#fb4934" }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator", "punctuation.accessor"],
      "settings": { "foreground": "#fe8019" }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "meta.function-call.generic", "support.function"],
      "settings": { "foreground": "#fabd2f" }
    },
    {
      "name": "Function parameter",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#ebdbb2", "fontStyle": "italic" }
    },
    {
      "name": "Type / Class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#8ec07c" }
    },
    {
      "name": "Interface / Type alias",
      "scope": ["entity.name.type.interface", "entity.name.type.alias"],
      "settings": { "foreground": "#8ec07c", "fontStyle": "italic" }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator", "entity.name.function.decorator"],
      "settings": { "foreground": "#83a598" }
    },
    {
      "name": "Variable",
      "scope": ["variable", "variable.other", "variable.other.readwrite"],
      "settings": { "foreground": "#ebdbb2" }
    },
    {
      "name": "Constant",
      "scope": ["variable.other.constant", "constant.other"],
      "settings": { "foreground": "#d3869b" }
    },
    {
      "name": "Object property",
      "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"],
      "settings": { "foreground": "#83a598" }
    },
    {
      "name": "Import / Module path",
      "scope": ["string.quoted.other.nix", "entity.name.module", "keyword.control.import", "keyword.control.export"],
      "settings": { "foreground": "#fb4934" }
    },
    {
      "name": "Tag name (HTML/JSX/XML)",
      "scope": ["entity.name.tag", "support.class.component"],
      "settings": { "foreground": "#fb4934" }
    },
    {
      "name": "Tag attribute",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#fabd2f" }
    },
    {
      "name": "Tag punctuation",
      "scope": ["punctuation.definition.tag"],
      "settings": { "foreground": "#928374" }
    },
    {
      "name": "CSS property",
      "scope": ["support.type.property-name.css", "entity.other.attribute-name.class.css"],
      "settings": { "foreground": "#fabd2f" }
    },
    {
      "name": "CSS value / unit",
      "scope": ["constant.numeric.css", "keyword.other.unit.css", "support.constant.property-value.css"],
      "settings": { "foreground": "#d3869b" }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#b8bb26" }
    },
    {
      "name": "Markdown heading",
      "scope": ["markup.heading", "entity.name.section.markdown", "punctuation.definition.heading.markdown"],
      "settings": { "foreground": "#fabd2f", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#fe8019", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#d3869b", "fontStyle": "italic" }
    },
    {
      "name": "Markdown inline code",
      "scope": ["markup.inline.raw", "markup.raw.inline"],
      "settings": { "foreground": "#8ec07c" }
    },
    {
      "name": "Markdown link",
      "scope": ["markup.underline.link", "string.other.link.title.markdown"],
      "settings": { "foreground": "#83a598" }
    },
    {
      "name": "Markdown quote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#928374", "fontStyle": "italic" }
    },
    {
      "name": "Nix attribute name",
      "scope": ["entity.other.attribute-name.multiline.nix", "variable.other.attribute.nix"],
      "settings": { "foreground": "#83a598" }
    },
    {
      "name": "Nix string interpolation",
      "scope": ["punctuation.section.embedded.nix"],
      "settings": { "foreground": "#8ec07c" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#a89984" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": { "foreground": "#282828", "background": "#fb4934" }
    }
  ]
}
