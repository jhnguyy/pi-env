    "list.highlightForeground":             "#fe8019",
    "list.errorForeground":                 "#fb4934",
    "list.warningForeground":               "#fabd2f",

    "editorGroupHeader.tabsBackground":   "#282828",
    "editorGroupHeader.tabsBorder":       "#3c3836",
