    "menu.selectionBackground":    "#504945",
    "menu.selectionForeground":    "#ebdbb2",
    "menu.separatorBackground":    "#504945",
    "menu.border":                 "#504945",

    "input.background":           "#3c3836",
    "input.foreground":           "#ebdbb2",
    "input.border":               "#504945",
    "input.placeholderForeground":"#665c54",
    "inputOption.activeBackground":"#504945",
    "inputOption.activeBorder":    "#83a598",

    "dropdown.background": "#3c3836",
    "dropdown.foreground": "#d5c4a1",
    "dropdown.border":     "#504945",

    "button.background":        "#d79921",
    "button.foreground":        "#282828",
