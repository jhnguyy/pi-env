    "scrollbarSlider.hoverBackground":   "#665c54cc",
    "scrollbarSlider.activeBackground":  "#7c6f64cc",

    "panel.background":        "#282828",
    "panel.border":            "#3c3836",
    "panelTitle.activeBorder": "#fe8019",
    "panelTitle.activeForeground":"#ebdbb2",
    "panelTitle.inactiveForeground":"#7c6f64",

    "terminal.background":         "#282828",
    "terminal.foreground":         "#ebdbb2",
    "terminal.selectionBackground":"#504945",
    "terminalCursor.foreground":   "#fe8019",
    "terminalCursor.background":   "#282828",
    "terminal.ansiBlack":          "#282828",
    "terminal.ansiRed":            "#cc241d",
    "terminal.ansiGreen":          "#98971a",
    "terminal.ansiYellow":         "#d79921",
    "terminal.ansiBlue":           "#458588",
    "terminal.ansiMagenta":        "#b16286",
    "terminal.ansiCyan":           "#689d6a",
    "terminal.ansiWhite":          "#a89984",
    "terminal.ansiBrightBlack":    "#928374",
    "terminal.ansiBrightRed":      "#fb4934",
    "terminal.ansiBrightGreen":    "#b8bb26",
    "terminal.ansiBrightYellow":   "#fabd2f",
    "terminal.ansiBrightBlue":     "#83a598",
    "terminal.ansiBrightMagenta":  "#d3869b",
    "terminal.ansiBrightCyan":     "#8ec07c",
    "terminal.ansiBrightWhite":    "#ebdbb2",

    "gitDecoration.addedResourceForeground":       "#b8bb26",
    "gitDecoration.modifiedResourceForeground":    "#fabd2f",
    "gitDecoration.deletedResourceForeground":     "#fb4934",
    "gitDecoration.untrackedResourceForeground":   "#8ec07c",
    "gitDecoration.ignoredResourceForeground":     "#665c54",
    "gitDecoration.conflictingResourceForeground": "#d3869b",
    "gitDecoration.stageDeletedResourceForeground":"#fb4934",
    "gitDecoration.stageModifiedResourceForeground":"#fabd2f",

    "focusBorder":               "#83a598",
    "foreground":                "#ebdbb2",
    "widget.shadow":             "#00000088",
    "selection.background":      "#504945",
    "descriptionForeground":     "#a89984",
    "errorForeground":           "#fb4934",
    "icon.foreground":           "#a89984",

    "notifications.background": "#3c3836",
    "notifications.foreground": "#d5c4a1",
    "notifications.border":     "#504945",
    "notificationCenterHeader.background": "#282828",
