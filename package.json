{
  "name": "pi-env",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    ".pi/extensions/analyze",
    ".pi/extensions/web-context",
    ".pi/extensions/dev-tools",
    ".pi/extensions/introspection",
    ".pi/extensions/jit-catch",
    ".pi/extensions/pi-update",
    ".pi/extensions/ptc",
    ".pi/extensions/security",
    ".pi/extensions/skill-builder",
    ".pi/extensions/subagent"
  ],
  "pi": {
    "extensions": [
      ".pi/extensions/analyze",
      ".pi/extensions/web-context",
      ".pi/extensions/dev-tools",
      ".pi/extensions/introspection",
      ".pi/extensions/jit-catch",
      ".pi/extensions/pi-update",
      ".pi/extensions/ptc",
      ".pi/extensions/security",
      ".pi/extensions/skill-builder",
      ".pi/extensions/subagent"
    ],
    "skills": [
      ".agents/skills"
    ],
    "themes": [
      "themes"
    ]
  },
  "scripts": {
    "check:node": "scripts/node-run.sh scripts/check-node-version.mjs",
    "build": "scripts/node-run.sh scripts/build-extensions.mjs",
    "clean:extensions": "scripts/node-run.sh scripts/clean-extension-artifacts.mjs",
    "test": "nub run test:unit",
    "test:unit": "scripts/node-run.sh node_modules/vitest/vitest.mjs run --pool=threads",
    "test:changed": "scripts/node-run.sh node_modules/vitest/vitest.mjs run --pool=threads --changed",
    "test:safe": "scripts/node-run.sh node_modules/vitest/vitest.mjs run --pool=threads --maxWorkers=1",
    "test:setup": "bash setup/__tests__/run.sh",
    "test:e2e": "E2E=1 scripts/node-run.sh node_modules/vitest/vitest.mjs run --pool=threads --maxWorkers=1",
    "typecheck": "scripts/node-run.sh node_modules/typescript/bin/tsc --noEmit",
    "lint:type": "scripts/tool-node-run.sh node_modules/oxlint/bin/oxlint . --type-aware --threads=1 --deny-warnings --ignore-pattern 'tests/**' --ignore-pattern '**/dist/**'",
    "format": "scripts/tool-node-run.sh node_modules/oxfmt/bin/oxfmt --threads=1 scripts/check-patterns.js scripts/heavyweight-lock.mjs scripts/safe-verification-plan.mjs scripts/verification-phases.mjs scripts/verification-plan.mjs scripts/verification-runner.mjs scripts/verify-phase.mjs scripts/verify-safe.mjs .oxlintrc.json .oxfmtrc.json",
    "format:check": "scripts/tool-node-run.sh node_modules/oxfmt/bin/oxfmt --threads=1 --check scripts/check-patterns.js scripts/heavyweight-lock.mjs scripts/safe-verification-plan.mjs scripts/verification-phases.mjs scripts/verification-plan.mjs scripts/verification-runner.mjs scripts/verify-phase.mjs scripts/verify-safe.mjs .oxlintrc.json .oxfmtrc.json",
    "analyze": "scripts/node-run.sh .pi/extensions/analyze/dist/cli.js",
    "sensors": "nub run analyze -- --diff --checks complexity,async-risk",
    "check:duplicates": "nub run analyze -- --checks duplicates . --fail-on error",
    "check:quality": "nub run analyze -- --all --checks duplicates,dependencies,knip --fail-on error && nub run check:patterns",
    "verify": "scripts/node-run.sh scripts/verify.mjs",
    "verify:safe": "scripts/node-run.sh scripts/verify-safe.mjs",
    "verify:install": "nub run build && scripts/node-run.sh scripts/verify-install.mjs",
    "verify:phase": "scripts/node-run.sh scripts/verify-phase.mjs",
    "postinstall": "sh scripts/restart-lsp-daemon.sh && scripts/node-run.sh scripts/build-extensions.mjs",
    "prepare": "scripts/node-run.sh node_modules/@effect/language-service/cli.js patch",
    "prebuild": "nub run check:node",
    "pretest:unit": "nub run check:node",
    "pretest:setup": "nub run check:node",
    "pretest:e2e": "nub run check:node",
    "pretypecheck": "nub run check:node",
    "preinstall": "nub run check:node",
    "check:patterns": "scripts/node-run.sh scripts/check-patterns.js",
    "security:trivy": "bash scripts/trivy-scan.sh"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.80.7",
    "@earendil-works/pi-ai": "0.80.7",
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@earendil-works/pi-tui": "0.80.7",
    "@effect/language-service": "^0.86.6",
    "@types/node": "^24.0.0",
    "dependency-cruiser": "^18.0.0",
    "esbuild": "^0.28.1",
    "knip": "^6.24.0",
    "typebox": "^1.2.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0"
  },
  "overrides": {
    "minimatch": "10.2.3",
    "protobufjs": "8.6.6"
  },
  "packageManager": "nub@0.2.10",
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.2.10",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "error"
    }
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.97",
    "@effect/platform-node": "4.0.0-beta.97",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/sdk-trace-node": "2.9.0",
    "effect": "4.0.0-beta.97"
  },
  "allowBuilds": {
    "@google/genai": true,
    "esbuild": true,
    "msgpackr-extract": false
  }
}
