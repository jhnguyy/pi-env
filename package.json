{
  "name": "pi-env",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    ".pi/extensions/web-context",
    ".pi/extensions/dev-tools",
    ".pi/extensions/jit-catch",
    ".pi/extensions/pi-update",
    ".pi/extensions/ptc",
    ".pi/extensions/security",
    ".pi/extensions/skill-builder",
    ".pi/extensions/subagent",
    ".pi/extensions/work-tracker"
  ],
  "pi": {
    "extensions": [
      ".pi/extensions/web-context",
      ".pi/extensions/dev-tools",
      ".pi/extensions/jit-catch",
      ".pi/extensions/pi-update",
      ".pi/extensions/ptc",
      ".pi/extensions/security",
      ".pi/extensions/skill-builder",
      ".pi/extensions/subagent",
      ".pi/extensions/work-tracker"
    ],
    "skills": [
      ".agents/skills"
    ],
    "themes": [
      "themes"
    ]
  },
  "scripts": {
    "check:node": "node -e \"const [major, minor] = process.versions.node.split('.').map(Number); if (major < 22 || (major === 22 && minor < 19)) { console.error('Node.js >= 22.19 is required; found ' + process.version); process.exit(1); }\"",
    "build": "node scripts/build-extensions.mjs",
    "clean:extensions": "node scripts/clean-extension-artifacts.mjs",
    "test": "nub run test:unit",
    "test:unit": "vitest run",
    "test:setup": "bash setup/__tests__/managed-settings.test.sh && bash setup/__tests__/nix-managed-config.test.sh && bash setup/__tests__/setup-options.test.sh && bash setup/__tests__/node-resolution.test.sh && bash setup/__tests__/pi-cli-wrapper.test.sh",
    "test:e2e": "E2E=1 vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "nub run test:setup && nub run typecheck && nub run build && nub run test:unit",
    "verify:install": "nub run build && node scripts/verify-install.mjs",
    "postinstall": "sh scripts/restart-lsp-daemon.sh && node scripts/build-extensions.mjs",
    "prebuild": "nub run check:node",
    "pretest:unit": "nub run check:node",
    "pretest:setup": "nub run check:node",
    "pretest:e2e": "nub run check:node",
    "pretypecheck": "nub run check:node",
    "preinstall": "nub run check:node"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "0.80.3",
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@earendil-works/pi-tui": "0.80.3",
    "@types/node": "^22.20.0",
    "esbuild": "^0.28.1",
    "typebox": "^1.2.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "minimatch": "10.2.3"
  },
  "packageManager": "nub@0.2.10",
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.2.10",
      "onFail": "warn"
    }
  }
}
