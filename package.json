{
  "name": "pi-env",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": ["pi-package"],
  "workspaces": [
    ".pi/extensions/*"
  ],
  "pi": {
    "extensions": [
      ".pi/extensions/ptc",
      ".pi/extensions/dev-tools",
      ".pi/extensions/jit-catch",
      ".pi/extensions/security",
      ".pi/extensions/skill-builder",
      ".pi/extensions/subagent",
      ".pi/extensions/usage-bar",
      ".pi/extensions/work-tracker"
    ],
    "skills": [".agents/skills"],
    "themes": ["themes"]
  },
  "scripts": {
    "build": "bash scripts/build-extensions.sh",
    "test": "bun test",
    "postinstall": "sh scripts/restart-lsp-daemon.sh && bash scripts/build-extensions.sh"
  },
  "peerDependencies": {
    "typebox": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.75.3",
    "@earendil-works/pi-coding-agent": "0.75.3",
    "@earendil-works/pi-tui": "0.75.3",
    "@types/bun": "latest",
    "typebox": "^1.1.24",
    "typescript": "^5.9.3"
  }
}
