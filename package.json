{
  "name": "pi-env",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "keywords": ["pi-package"],
  "workspaces": [
    ".pi/extensions/*"
  ],
  "pi": {
    "extensions": [".pi/extensions/ptc", ".pi/extensions", "!.pi/extensions/tmux/**"],
    "skills": [".agents/skills"],
    "themes": ["themes"]
  },
  "scripts": {
    "build": "bash scripts/build-extensions.sh",
    "test": "bun test",
    "postinstall": "sh scripts/restart-lsp-daemon.sh && bash scripts/build-extensions.sh"
  },
  "peerDependencies": {
    "typebox": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.70.0",
    "@mariozechner/pi-coding-agent": "0.70.0",
    "@mariozechner/pi-tui": "0.70.0",
    "typebox": "^1.1.24",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
