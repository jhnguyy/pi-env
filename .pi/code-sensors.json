{
  "version": 1,
  "sensors": [
    {
      "name": "dependency-cruiser",
      "command": "nub run check:deps",
      "include": [".pi/extensions/", ".dependency-cruiser.cjs"],
      "timeoutMs": 120000,
      "severity": "error"
    },
    {
      "name": "jscpd",
      "command": "nub run check:clones",
      "include": [".pi/extensions/", ".jscpd.json"],
      "timeoutMs": 120000,
      "severity": "warning"
    },
    {
      "name": "knip",
      "command": "nub run check:unused",
      "include": [".pi/extensions/", "scripts/", "setup/", "knip.json", "package.json"],
      "timeoutMs": 120000,
      "severity": "warning"
    },
    {
      "name": "patterns",
      "command": "nub run check:patterns",
      "include": [".pi/extensions/", "scripts/check-patterns.js"],
      "timeoutMs": 120000,
      "severity": "warning"
    },
    {
      "name": "trivy",
      "command": "nub run check:security",
      "include": ["package.json", "lock.yaml", "scripts/check-security.sh"],
      "timeoutMs": 300000,
      "severity": "error"
    }
  ]
}
