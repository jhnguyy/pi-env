{
  "extensionsDir": ".pi/extensions",
  "externals": [
    "@earendil-works/pi-coding-agent",
    "@earendil-works/pi-ai",
    "@earendil-works/pi-tui",
    "@earendil-works/pi-agent-core",
    "typebox",
    "@sinclair/typebox",
    "effect",
    "esbuild",
    "playwright"
  ],
  "sidecars": {
    "dev-tools": [
      {
        "entry": "daemon.ts",
        "outfile": "dist/daemon.js",
        "banner": false
      }
    ],
    "ptc": [
      {
        "entry": "subprocess-preamble.ts",
        "outfile": "dist/subprocess-preamble.js",
        "banner": false
      }
    ]
  }
}
