{
  "extensionsDir": ".pi/extensions",
  "externals": [
    "@earendil-works/pi-coding-agent",
    "@earendil-works/pi-ai",
    "@earendil-works/pi-tui",
    "@earendil-works/pi-agent-core",
    "typebox",
    "@sinclair/typebox",
    "@effect/opentelemetry",
    "@opentelemetry/api",
    "@opentelemetry/exporter-trace-otlp-http",
    "@opentelemetry/sdk-trace-node",
    "effect",
    "esbuild",
    "playwright"
  ],
  "sidecars": {
    "analyze": [
      {
        "entry": "worker-main.ts",
        "outfile": "dist/worker.js"
      },
      {
        "entry": "cli-main.ts",
        "outfile": "dist/cli.js"
      }
    ],
    "dev-tools": [
      {
        "entry": "daemon.ts",
        "outfile": "dist/daemon.js",
        "banner": false
      }
    ],
    "ptc": [
      {
        "entry": "subprocess-preamble.ts",
        "outfile": "dist/subprocess-preamble.js",
        "banner": false
      }
    ]
  }
}
