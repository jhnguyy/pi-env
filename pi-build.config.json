{
  "extensionsDir": ".pi/extensions",
  "extensions": [
    "dev-tools",
    "jit-catch",
    "playwright-client",
    "pi-update",
    "ptc",
    "security",
    "skill-builder",
    "subagent",
    "theme-scheduler",
    "work-tracker"
  ],
  "externals": [
    "@earendil-works/pi-coding-agent",
    "@earendil-works/pi-ai",
    "@earendil-works/pi-tui",
    "@earendil-works/pi-agent-core",
    "typebox",
    "@sinclair/typebox",
    "esbuild",
    "playwright"
  ],
  "sidecars": {
    "dev-tools": [
      {
        "entry": "daemon.ts",
        "outfile": "dist/daemon.js",
        "banner": false
      }
    ],
    "ptc": [
      {
        "entry": "subprocess-preamble.ts",
        "outfile": "dist/subprocess-preamble.js",
        "banner": false
      }
    ]
  }
}
